# Never commit a real token.
IMAGE_API_KEY=replace_with_your_token

# Usually include /v1 for OpenAI-compatible relays.
IMAGE_API_BASE_URL=https://your-relay.example.com/v1

# The provider-facing model name or alias.
IMAGE_API_MODEL=image-2

# Required when the alias hides the underlying capability family.
# Allowed: auto, gpt-image-2, gpt-image-1.5, generic
IMAGE_API_MODEL_FAMILY=gpt-image-2

# Optional full endpoint overrides for nonstandard relays.
# IMAGE_API_GENERATIONS_URL=https://your-relay.example.com/v1/images/generations
# IMAGE_API_EDITS_URL=https://your-relay.example.com/v1/images/edits

IMAGE_API_TIMEOUT=180
IMAGE_API_MAX_RETRIES=3
IMAGE_API_VERIFY_SSL=true

# Optional JSON object. Keep authorization values out of committed files.
# IMAGE_API_EXTRA_HEADERS={"X-Client-Id":"your-client-id"}
IMAGE_API_EXTRA_HEADERS={}
