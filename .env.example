# Never commit a real token.
IMAGE_API_KEY=replace_with_your_token

# Usually include /v1 for OpenAI-compatible relays.
IMAGE_API_BASE_URL=https://your-relay.example.com/v1

# The provider-facing model name or alias.
IMAGE_API_MODEL=image-2

# Required when the alias hides the underlying capability family.
# Allowed: auto, gpt-image-2, gpt-image-1.5, generic
IMAGE_API_MODEL_FAMILY=gpt-image-2

# Optional full endpoint overrides for nonstandard relays.
# IMAGE_API_GENERATIONS_URL=https://your-relay.example.com/v1/images/generations
# IMAGE_API_EDITS_URL=https://your-relay.example.com/v1/images/edits

IMAGE_API_TIMEOUT=180
IMAGE_API_MAX_RETRIES=3
IMAGE_API_VERIFY_SSL=true

# Optional JSON object. Keep authorization values out of committed files.
# IMAGE_API_EXTRA_HEADERS={"X-Client-Id":"your-client-id"}
IMAGE_API_EXTRA_HEADERS={}

# ── Multi-provider fallback (optional) ──────────────────────
# When IMAGE_API_PROVIDERS is set, the variables above are IGNORED and each
# provider gets its own IMAGE_API_<NAME>_* set. Requests are tried in order;
# fallback-eligible errors (default 429, 500, 502, 503, 504, network_error)
# cause the next provider to be tried automatically.

# IMAGE_API_PROVIDERS=fenno,backup
#
# IMAGE_API_FENNO_KEY=sk-fenno-...
# IMAGE_API_FENNO_BASE_URL=https://api.fenno.ai/v1
# IMAGE_API_FENNO_MODEL=gpt-image-2
# IMAGE_API_FENNO_MODEL_FAMILY=gpt-image-2
# IMAGE_API_FENNO_TIMEOUT=180
# IMAGE_API_FENNO_MAX_RETRIES=2
# IMAGE_API_FENNO_VERIFY_SSL=true
# IMAGE_API_FENNO_EXTRA_HEADERS={}
#
# IMAGE_API_BACKUP_KEY=sk-backup-...
# IMAGE_API_BACKUP_BASE_URL=https://backup.example.com/v1
# IMAGE_API_BACKUP_MODEL=gpt-image-2
# IMAGE_API_BACKUP_MODEL_FAMILY=gpt-image-2
# IMAGE_API_BACKUP_TIMEOUT=180
# IMAGE_API_BACKUP_MAX_RETRIES=2
# IMAGE_API_BACKUP_VERIFY_SSL=true
#
# Override the default fallback trigger set if needed:
# IMAGE_API_FALLBACK_STATUS=429,500,502,503,504,network_error
# (Use comma-separated integers and/or the literal token "network_error".)
